# Daraja / M-Pesa secrets for the mpesa-stk + mpesa-callback edge functions.
#
# Usage:
#   1. cp supabase/.env.mpesa.example supabase/.env.mpesa
#   2. fill in the real values below
#   3. ./scripts/set-mpesa-secrets.sh
#
# supabase/.env.mpesa is gitignored — never commit real keys.

# --- Daraja app credentials (Safaricom developer portal) ---
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret

# --- Environment: sandbox | production ---
MPESA_ENV=sandbox

# --- STK passkey ---
# Sandbox shared passkey:
#   bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# Production: get the passkey for your shortcode from the portal / Safaricom.
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# --- Transaction type ---
# Sandbox test shortcode 174379 is a Paybill -> CustomerPayBillOnline
# Production Kichana Till                    -> CustomerBuyGoodsOnline
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# --- Shortcodes ---
# Sandbox: set both to 174379.
# Production: STORE = Head Office / Store Number, TILL = Buy Goods Till.
MPESA_STORE_NUMBER=174379
MPESA_TILL_NUMBER=174379

# --- Callback URL (point at YOUR Supabase project) ---
MPESA_CALLBACK_URL=https://your-project-ref.supabase.co/functions/v1/mpesa-callback
